# PostgreSQL — use full connection string
# Local:   postgresql://joblens:joblens@localhost:5432/joblens
# Railway: copied automatically from the Railway Postgres plugin
# Neon:    postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://joblens:joblens@localhost:5432/joblens

# Anthropic API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# CORS — comma-separated list of allowed origins (no trailing slash)
# Local:      http://localhost:3000
# Production: https://yourapp.vercel.app
CORS_ORIGINS=http://localhost:3000

# Optional: protects saved jobs/skills endpoints from public access
# Set the same value in NEXT_PUBLIC_PERSONAL_TOKEN on the frontend
PERSONAL_TOKEN=
